  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }


body {
  font-family: 'IBM Plex Sans Arabic', sans-serif;
  background: transparent;
  padding: 24px 16px;
}

.grid {
  display: flex;
  flex-direction: column;
  gap: 16px;
  max-width: 680px;
  margin: 0 auto;
}

.card {
  background: #ffffff;
  border: 1px solid #e0e0e0;
  border-radius: 12px;
  overflow: hidden;
  display: flex;
  align-items: stretch;
  text-decoration: none;
  color: inherit;
  transition: box-shadow 0.2s ease, transform 0.2s ease;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}

.card:hover {
  box-shadow: 0 6px 20px rgba(0,0,0,0.12);
  transform: translateY(-2px);
}

.card-accent {
  width: 6px;
  flex-shrink: 0;
  background: linear-gradient(180deg, #0a66c2, #004f9a);
}

.card-body {
  padding: 18px 20px;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 10px;
}

.linkedin-icon {
  width: 32px;
  height: 32px;
  background: #0a66c2;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.linkedin-icon svg {
  width: 18px;
  height: 18px;
  fill: white;
}

.club-name {
  font-size: 13px;
  font-weight: 600;
  color: #0a66c2;
}

.platform-label {
  font-size: 11px;
  color: #888;
}

.card-title {
  font-size: 15px;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.6;
}

.card-cta {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  font-weight: 600;
  color: #0a66c2;
  margin-top: 4px;
}

.card-cta svg {
  width: 14px;
  height: 14px;
  stroke: #0a66c2;
  fill: none;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
  /* flip arrow for RTL */
  transform: scaleX(-1);
}

.card-number {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: #f0f4ff;
  color: #0a66c2;
  font-size: 12px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.browse-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  width: 100%;
  padding: 14px 20px;
  background: #0a66c2;
  color: #ffffff;
  font-family: 'IBM Plex Sans Arabic', sans-serif;
  font-size: 15px;
  font-weight: 700;
  border-radius: 12px;
  text-decoration: none;
  transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  box-shadow: 0 2px 8px rgba(10,102,194,0.25);
  margin-top: 4px;
}
.browse-btn:hover { background: #004f9a; transform: translateY(-2px); box-shadow: 0 6px 20px rgba(10,102,194,0.35); }
.browse-btn svg { width: 20px; height: 20px; fill: white; flex-shrink: 0; }
.browse-btn .arrow { width: 16px; height: 16px; stroke: white; fill: none; stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round; transform: scaleX(-1); flex-shrink: 0; }

  </style>
</head>
