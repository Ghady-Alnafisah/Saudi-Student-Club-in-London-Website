<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LinkedIn Post - النادي السعودي في لندن</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;900&display=swap');
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Tajawal', sans-serif;
    background: #f3f2ef;
    display: flex; justify-content: center;
    padding: 30px 16px;
    min-height: 100vh;
  }
  .post-card {
    background: white;
    border-radius: 8px;
    box-shadow: 0 0 0 1px rgba(0,0,0,0.08), 0 2px 8px rgba(0,0,0,0.06);
    max-width: 552px;
    width: 100%;
    overflow: hidden;
    animation: fadeUp 0.5s ease;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .post-header {
    padding: 12px 16px 0;
    display: flex; align-items: flex-start; gap: 10px;
  }
  .avatar {
    width: 48px; height: 48px; border-radius: 50%;
    background: linear-gradient(135deg, #1a5c2a, #2d9e4f);
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; border: 1px solid #e0e0e0; flex-shrink: 0;
  }
  .header-info { flex: 1; }
  .org-name { font-size: 14px; font-weight: 700; color: rgba(0,0,0,0.9); line-height: 1.3; cursor: pointer; }
  .org-name:hover { color: #0A66C2; text-decoration: underline; }
  .org-followers { font-size: 12px; color: rgba(0,0,0,0.6); margin-top: 1px; }
  .post-time { font-size: 12px; color: rgba(0,0,0,0.6); margin-top: 1px; display: flex; align-items: center; gap: 4px; }
  .post-time svg { width: 12px; height: 12px; fill: rgba(0,0,0,0.5); }
  .follow-btn {
    background: none; border: none; cursor: pointer;
    color: #0A66C2; font-family: 'Tajawal', sans-serif;
    font-size: 14px; font-weight: 600; padding: 4px 0;
    display: flex; align-items: center; gap: 4px; flex-shrink: 0;
  }
  .post-text {
    padding: 12px 16px;
    font-size: 14px; line-height: 1.7; color: rgba(0,0,0,0.9);
  }
  .post-text .hashtag { color: #0A66C2; cursor: pointer; font-weight: 500; }

  /* 2x2 equal grid */
  .gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 220px 220px;
    gap: 2px;
    background: #000;
  }
  .gallery-item { overflow: hidden; cursor: pointer; }
  .gallery-item img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
    transition: transform 0.25s ease;
  }
  .gallery-item:hover img { transform: scale(1.04); }

  .reactions-bar {
    padding: 8px 16px;
    display: flex; align-items: center; justify-content: space-between;
    border-bottom: 1px solid #e0e0e0;
  }
  .emoji-stack { display: flex; }
  .emoji-stack span {
    width: 18px; height: 18px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; background: white; border: 1px solid #e0e0e0;
    margin-left: -4px;
  }
  .emoji-stack span:first-child { margin-left: 0; }
  .reaction-count { font-size: 13px; color: rgba(0,0,0,0.6); margin-right: 6px; }
  .comment-count { font-size: 13px; color: rgba(0,0,0,0.6); cursor: pointer; }
  .comment-count:hover { color: #0A66C2; text-decoration: underline; }

  .action-bar {
    padding: 4px 8px;
    display: flex; align-items: center;
    border-bottom: 1px solid #e0e0e0;
  }
  .action-btn {
    flex: 1; display: flex; align-items: center; justify-content: center;
    gap: 6px; padding: 10px 8px;
    border: none; background: none; cursor: pointer;
    border-radius: 4px; color: rgba(0,0,0,0.6);
    font-family: 'Tajawal', sans-serif; font-size: 13px; font-weight: 600;
    transition: background 0.15s;
  }
  .action-btn:hover { background: rgba(0,0,0,0.06); color: rgba(0,0,0,0.9); }
  .action-btn svg { width: 20px; height: 20px; fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }

  .comments-section { padding: 12px 16px; }
  .comment { display: flex; gap: 10px; margin-bottom: 12px; }
  .comment-avatar {
    width: 36px; height: 36px; border-radius: 50%; flex-shrink: 0;
    background: linear-gradient(135deg, #0A66C2, #004182);
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; color: white; font-weight: 700;
  }
  .comment-bubble {
    background: #f3f2ef; border-radius: 0 8px 8px 8px;
    padding: 8px 12px; flex: 1;
  }
  .comment-author { font-size: 13px; font-weight: 700; color: rgba(0,0,0,0.9); }
  .comment-text { font-size: 13px; color: rgba(0,0,0,0.8); line-height: 1.5; margin-top: 2px; }
  .comment-time { font-size: 11px; color: rgba(0,0,0,0.5); margin-top: 4px; }

  .view-original {
    padding: 12px 16px;
    border-top: 1px solid #e0e0e0;
    text-align: center;
  }
  .view-link {
    display: inline-flex; align-items: center; gap: 8px;
    color: #0A66C2; text-decoration: none; font-size: 13px; font-weight: 600;
    padding: 8px 16px; border: 1.5px solid #0A66C2; border-radius: 24px;
    transition: all 0.2s;
  }
  .view-link:hover { background: #0A66C2; color: white; }
  .view-link svg { width: 15px; height: 15px; fill: currentColor; }
</style>
