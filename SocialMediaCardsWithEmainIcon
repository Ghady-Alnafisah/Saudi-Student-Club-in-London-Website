  .icon-em { background: #fef3cd; color: #7a4f00; }
  .chevron { font-size: 8px; color: #888; transition: transform 0.16s, color 0.12s; line-height: 1; padding: 0 4px; }
  .card-menu { position: absolute; bottom: calc(100% + 8px); left: 0; background: #fff; border: 1.5px solid #1a1a1a; border-radius: 6px; min-width: 220px; box-shadow: 0 4px 24px rgba(0,0,0,0.13); overflow: hidden; display: none; z-index: 100; }
