  .social-btn:hover, .single-btn:hover { filter: brightness(0.93); }
  .social-item.open .social-btn { background: #1a1a1a; }
  .social-item.open .social-btn .icon-wa { background: #2a7a30; color: #fff; }
  .social-item.open .social-btn .icon-tg { background: #1a6fa8; color: #fff; }
  .social-item.open .social-btn .chevron { color: #ccc; transform: rotate(180deg); }
  .platform-icon { width: 30px; height: 30px; border-radius: 2px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: background 0.12s, color 0.12s; }
  .platform-icon svg { width: 15px; height: 15px; display: block; }
  .icon-wa { background: #d4edda; color: #145a20; }
  .icon-tg { background: #d0e8f5; color: #0a4d74; }
