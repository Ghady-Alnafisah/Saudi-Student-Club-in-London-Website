  .card-menu-accent { width: 4px; height: 18px; border-radius: 2px; flex-shrink: 0; }
  .divider-v { width: 1.5px; height: 26px; background: #1a1a1a; align-self: center; margin: 0 20px 0 0; opacity: 0.15; flex-shrink: 0; }
